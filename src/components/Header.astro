---
import Logo from '../components/Logo.astro';

const navItems = [
    { linkText: 'Home', href: '/' },
    { linkText: 'About', href: '/about' },
    { linkText: 'Gallery', href: '/gallery' },
    { linkText: 'Contact', href: '/contact' }
];

const currentPath = Astro.url.pathname;
---

<nav class="flex flex-wrap items-center justify-between gap-4 pt-6 pb-12 sm:pt-10 sm:pb-20">
    <a href="/" class="logo-link flex items-center gap-3 no-underline group">
        <Logo />
        <span class="text-xl font-bold text-gradient-gold tracking-wide">Lightforged Creations</span>
    </a>
    {
        !!navItems?.length && (
            <ul class="flex flex-wrap gap-x-1 gap-y-1">
                {navItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            class:list={[
                                'nav-link inline-block px-4 py-2 rounded-lg text-sm font-medium no-underline transition-all duration-300',
                                currentPath === item.href
                                    ? 'text-cosmic-900 bg-gold-400'
                                    : 'text-star-white/80 hover:text-gold-300 hover:bg-star-white/5'
                            ]}
                        >
                            {item.linkText}
                        </a>
                    </li>
                ))}
            </ul>
        )
    }
</nav>
