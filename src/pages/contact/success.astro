---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Message Sent" description="Your message has been received. We'll be in touch soon.">
    <section class="py-20 sm:py-32 text-center">
        <div class="max-w-lg mx-auto">
            <div class="text-5xl mb-6">&#10024;</div>
            <h1 class="mb-6">
                <span class="text-gradient-gold">Message Sent!</span>
            </h1>
            <p class="text-star-white/70 text-lg mb-10 leading-relaxed">
                Thank you for reaching out. Your message has been received and we'll get back
                to you as soon as possible.
            </p>
            <a href="/" class="btn btn-primary btn-lg">Back to Home</a>
        </div>
    </section>
</Layout>
