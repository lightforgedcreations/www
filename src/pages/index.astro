---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lightforged Creations – Precision Cosmic Engraving">

  <!-- ================= HEADER ================= -->
  <header class="cosmic-header">
    <div class="header-inner">
      <img src="/assets/anvil-icon.png" class="logo" alt="Lightforged Logo">

      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/gallery">Gallery</a>
        <a href="/shop">Shop</a>
        <a href="/contact">Contact</a>
        <a href="/shop" class="cta">Start an Order</a>
      </nav>
    </div>
  </header>

  <!-- ================= HERO ================= -->
  <section class="hero">
    <div class="hero-content">
      <h1>Precision Engraving. Cosmic Craft.</h1>
      <p>Custom laser engraving on metal, wood, acrylic, leather, and more.</p>
      <a href="/gallery" class="hero-btn">View Gallery</a>
    </div>
  </section>

  <!-- ================= FEATURED ================= -->
  <section class="featured">
    <h2>Featured Work</h2>

    <div class="gallery-grid">
      <img src="/assets/featured-card-1.jpg" alt="Engraved aluminum card">
      <img src="/assets/featured-card-2.jpg" alt="Engraved aluminum card">
      <img src="/assets/featured-card-3.jpg" alt="Engraved aluminum card">
    </div>
  </section>

  <!-- ================= VALUE ================= -->
  <section class="value">
    <h2>Why Choose Lightforged?</h2>

    <div class="value-grid">
      <div>
        <h3>Cosmic Identity</h3>
        <p>Your engraving isn’t just a product — it’s forged in light, precision, and creativity.</p>
      </div>

      <div>
        <h3>Premium Materials</h3>
        <p>Aluminum, leather, wood, acrylic — each engraved with crisp detail and durability.</p>
      </div>

      <div>
        <h3>Custom Craftsmanship</h3>
        <p>Every piece is engraved to order with care, accuracy, and artistic intent.</p>
      </div>
    </div>
  </section>

</Layout>
